# Environment Variables Example
# Copy this file to .env.local and update with your values

# Company Information
REACT_APP_COMPANY_NAME=Trucking Dispatch Pro
REACT_APP_PHONE_NUMBER=555-123-4567
REACT_APP_EMAIL=info@truckingdispatchpro.com
REACT_APP_WEBSITE=https://truckingdispatchpro.com

# Social Media Links
REACT_APP_FACEBOOK_URL=https://facebook.com/truckingdispatchpro
REACT_APP_TWITTER_URL=https://twitter.com/truckingdispatchpro
REACT_APP_LINKEDIN_URL=https://linkedin.com/company/truckingdispatchpro

# Analytics (Optional)
REACT_APP_GA_TRACKING_ID=
REACT_APP_HOTJAR_ID=

# API Configuration (Optional)
REACT_APP_API_URL=
REACT_APP_API_KEY=

# Feature Flags
REACT_APP_ENABLE_ANALYTICS=false
REACT_APP_ENABLE_CHAT_WIDGET=false
